@page
@using Usuarios.Modelos
@model Usuarios.Pages.UsuariosModel

<h1>Gestión de P-Studios</h1>

<form method="post" class="mb-4">
    <input type="hidden" asp-for="NuevoDesarrollador.Id" />

    <input type="text" asp-for="NuevoDesarrollador.Username" placeholder="Usuario Roblox" required /><br />
    <input type="text" asp-for="NuevoDesarrollador.Rol" placeholder="Rol" required /><br />
    <input type="text" asp-for="NuevoDesarrollador.JuegoAsignado" placeholder="Juego Asignado" required /><br />
    <input type="number" asp-for="NuevoDesarrollador.RobuxGenerados" placeholder="Robux Generados" required /><br />
    <input type="text" asp-for="NuevoDesarrollador.Estatus" placeholder="Estatus" required /><br />

    <button type="submit" class="btn btn-primary">Guardar</button>

    @if (Model.NuevoDesarrollador?.Id > 0)
    {
        <button type="submit" asp-page-handler="Eliminar" class="btn btn-danger" onclick="return confirm('¿Estás seguro de que deseas eliminar a este desarrollador de P-Studios?');">
            Eliminar
        </button>
    }

    <a href="/Usuarios" class="btn btn-secondary">Limpiar</a>
</form>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Rol</th>
            <th>Juego</th>
            <th>Robux</th>
            <th>Estatus</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Desarrollador dev in Model.Desarrolladores)
        {
            <tr>
                <td>@dev.Id</td>
                <td>@dev.Username</td>
                <td>@dev.Rol</td>
                <td>@dev.JuegoAsignado</td>
                <td>@dev.RobuxGenerados</td>
                <td>@dev.Estatus</td>
                <td>
                    <a href="/Usuarios?editarId=@dev.Id" class="btn btn-primary btn-sm">Editar</a>
                </td>
            </tr>
        }
    </tbody>
</table>