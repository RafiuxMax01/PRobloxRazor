@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio - P-Studios";
}

<div class="text-center mt-5">
    <h1 class="display-3 fw-bold" style="color: #00A2FF; text-shadow: 0 0 20px rgba(0, 162, 255, 0.6);">
        ¡Bienvenido a P-Studios!
    </h1>

    <p class="lead mt-4 mb-5" style="color: #F2F4F5; font-size: 1.5rem;">
        Desarrollando el futuro del entretenimiento y estilo en Roblox.
    </p>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card p-4 shadow-lg text-center">
                <h3 class="text-white mb-3">¿Quiénes somos?</h3>
                <p style="color: #B8B8B8; font-size: 1.1rem;">
                    Somos un grupo de desarrollo enfocado en crear experiencias inmersivas, simuladores divertidos y la mejor ropa UGC del catálogo. Fundado por talento de LITC, estamos listos para romper los límites de Roblox Studio.
                </p>

                <div class="mt-4">
                    <a href="/Juegos" class="btn btn-primary btn-lg mx-2 mb-2">
                        Explorar Juegos 🎮
                    </a>
                    <a href="/Ropa" class="btn btn-secondary btn-lg mx-2 mb-2" style="background-color: #00B06F; border: none;">
                        Ver Catálogo 👕
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <p class="text-muted">
            <small>Únete a nuestro grupo de Roblox para recibir recompensas exclusivas.</small>
        </p>
    </div>
</div>  